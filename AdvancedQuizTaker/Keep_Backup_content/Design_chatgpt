const ROOT_FOLDER_ID = "PASTE_YOUR_ROOT_ID";
2.1 Folder Access Layer
function getFolder(name) {
  const root = DriveApp.getFolderById(ROOT_FOLDER_ID);
  const folders = root.getFoldersByName(name);
  return folders.hasNext() ? folders.next() : null;
}
2.2 Read CSV Utility
function readCSV(file) {
  const content = file.getBlob().getDataAsString();
  return Utilities.parseCsv(content);
}
2.3 Get Quiz Topics (Folders inside Questions Data)
function getTopics() {
  const folder = getFolder("Questions Data");
  const subFolders = folder.getFolders();

  let topics = [];
  while (subFolders.hasNext()) {
    topics.push(subFolders.next().getName());
  }

  return topics;
}
2.4 Load Questions (Filtered)
function getQuestions(filters) {
  const folder = getFolder("Questions Data");

  let allQuestions = [];

  const topicFolders = folder.getFolders();

  while (topicFolders.hasNext()) {
    let topicFolder = topicFolders.next();

    if (!filters.topics.includes(topicFolder.getName())) continue;

    let files = topicFolder.getFiles();

    while (files.hasNext()) {
      let file = files.next();
      let data = readCSV(file);

      data.slice(1).forEach(row => {
        let q = {
          question: row[0],
          category: row[1],
          subcategory: row[2],
          tags: row[3],
          difficulty: row[4],
          type: row[5],
          options: row.slice(6, 10),
          answer: row[10]
        };

        // Apply filters
        if (filters.category && filters.category.length && !filters.category.includes(q.category)) return;
        if (filters.difficulty && !filters.difficulty.includes(q.difficulty)) return;

        allQuestions.push(q);
      });
    }
  }

  return allQuestions;
}
2.5 Load Quiz Config
function getQuizConfig() {
  const folder = getFolder("Quiz Config Data");
  const file = folder.getFilesByName("quiz_config.csv").next();

  return readCSV(file);
}
2.6 Save Result (Main + Detailed File)
function saveResult(payload) {
  const folder = getFolder("Result Data");

  // Append summary
  const file = folder.getFilesByName("Result_Data.csv").next();
  const sheet = SpreadsheetApp.openById(file.getId()).getSheets()[0];

  sheet.appendRow([
    payload.name,
    payload.score,
    payload.time,
    payload.fileId
  ]);

  // Save detailed attempt
  const newFile = folder.createFile(
    `attempt_${Date.now()}.csv`,
    payload.detailCSV
  );

  return newFile.getId();
}
2.7 API Entry
function doPost(e) {
  const action = e.parameter.action;
  const data = JSON.parse(e.postData.contents);

  switch (action) {
    case "getTopics":
      return json(getTopics());

    case "getQuestions":
      return json(getQuestions(data));

    case "getConfig":
      return json(getQuizConfig());

    case "saveResult":
      return json(saveResult(data));
  }
}

function json(data) {
  return ContentService
    .createTextOutput(JSON.stringify(data))
    .setMimeType(ContentService.MimeType.JSON);
}
